<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:context="http://www.springframework.org/schema/context" xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
        http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context.xsd"> <!-- bean definitions here -->
	
	<context:component-scan base-package="com.spring.project1"></context:component-scan>

    <!-- bean definitions here -->
    <bean id="std" class="com.coders.demo.entity.Student" autowire="constructor">
    <constructor-arg value="1"></constructor-arg>
    <constructor-arg value="Manoj"></constructor-arg>
    <constructor-arg value="23"></constructor-arg>
    <constructor-arg value="20000"></constructor-arg>
    
    </bean>
    
    <bean id="emp" class="com.coders.demo.entity.Employee">    
    <constructor-arg value="1"></constructor-arg>
    <constructor-arg value="Manoj"></constructor-arg>
    <constructor-arg value="23"></constructor-arg>
    <constructor-arg value="20000"></constructor-arg>
    
    </bean>
    
    <bean id="location" class="com.coders.demo.entity.Location" autowire="constructor">
    <!--  
    <property name="lid" value="1"></property>
    <property name="city" value="Hyderabad"></property>
    -->
    
    </bean>
	<!--  
	<bean id="location2" class="com.coders.demo.entity.Location2" primary="true"></bean>
    -->
</beans>